#!/bin/sh
# =============================================================
# AI Code Review - Pre-Commit Hook
# Menggunakan: claude -p (print mode) — sesuai Claude Code CLI
# =============================================================

# ── Konfigurasi ──────────────────────────────────────────────
LOG_DIR="logs/reviews"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached")
LOG_FILE="$LOG_DIR/review_${TIMESTAMP}.json"
TEMP_DIFF=".claude-diff-temp.txt"
TEMP_RESULT=".claude-result-temp.txt"

# Warna terminal
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# ── Pastikan PATH lengkap (claude bisa ditemukan) ─────────────
export PATH="$PATH:/usr/local/bin:$HOME/.npm-global/bin:$HOME/.local/bin"

# ── Cek claude CLI tersedia ───────────────────────────────────
if ! command -v claude > /dev/null 2>&1; then
  echo "${YELLOW}⚠ Claude Code CLI tidak ditemukan. Skip AI review.${NC}"
  echo "  Install: npm install -g @anthropic-ai/claude-code"
  exit 0
fi

# ── Ambil staged files ────────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "${BLUE}ℹ Tidak ada file staged. Skip review.${NC}"
  exit 0
fi

FILE_COUNT=$(echo "$STAGED_FILES" | wc -l | tr -d ' ')

# ── Ambil diff dari staged files ─────────────────────────────
git diff --cached > "$TEMP_DIFF"
DIFF_SIZE=$(wc -c < "$TEMP_DIFF")

echo ""
echo "${BLUE}┌─────────────────────────────────────────┐${NC}"
echo "${BLUE}│   🤖 Claude Code - AI Pre-Commit Review  │${NC}"
echo "${BLUE}└─────────────────────────────────────────┘${NC}"
echo "  Branch : $BRANCH"
echo "  Files  : $FILE_COUNT file(s)"
echo "  Time   : $(date '+%Y-%m-%d %H:%M:%S')"
echo ""

# ── Jika diff terlalu besar, potong ──────────────────────────
MAX_DIFF_CHARS=8000
if [ "$DIFF_SIZE" -gt "$MAX_DIFF_CHARS" ]; then
  echo "${YELLOW}⚠ Diff besar ($DIFF_SIZE chars), dipotong untuk review.${NC}"
  DIFF_CONTENT=$(head -c $MAX_DIFF_CHARS "$TEMP_DIFF")
else
  DIFF_CONTENT=$(cat "$TEMP_DIFF")
fi

# ── Buat prompt untuk Claude ──────────────────────────────────
PROMPT="Kamu adalah senior code reviewer. Review git diff berikut dan berikan output HANYA dalam format JSON valid (tanpa markdown, tanpa backtick, tanpa penjelasan tambahan).

Format JSON yang WAJIB diikuti:
{
  \"score\": <angka 0-100>,
  \"status\": \"PASSED\" atau \"BLOCKED\",
  \"summary\": \"<ringkasan singkat dalam 1 kalimat>\",
  \"issues\": [
    {
      \"severity\": \"blocking\" atau \"warning\" atau \"info\",
      \"file\": \"<nama file>\",
      \"line\": <nomor baris atau null>,
      \"message\": \"<deskripsi issue>\"
    }
  ]
}

Aturan status:
- BLOCKED jika ada issue dengan severity 'blocking' (security hole, bug kritis, hardcoded secret)
- PASSED jika tidak ada blocking issue

Git diff yang direview:
${DIFF_CONTENT}"

# ── Jalankan Claude review ────────────────────────────────────
echo "${BLUE}⏳ Menjalankan AI review...${NC}"
REVIEW_START=$(date +%s)

echo "$PROMPT" | claude -p --output-format text > "$TEMP_RESULT" 2>&1
CLAUDE_EXIT=$?

REVIEW_END=$(date +%s)
REVIEW_DURATION=$((REVIEW_END - REVIEW_START))

# ── Parse hasil JSON dari Claude ──────────────────────────────
RESULT_RAW=$(cat "$TEMP_RESULT")

# Bersihkan jika ada markdown fence
RESULT_JSON=$(echo "$RESULT_RAW" | sed 's/```json//g' | sed 's/```//g' | tr -d '\r')

if command -v jq > /dev/null 2>&1; then
  # Validasi JSON
  echo "$RESULT_JSON" | jq . > /dev/null 2>&1
  JSON_VALID=$?

  if [ "$JSON_VALID" -eq 0 ]; then
    SCORE=$(echo "$RESULT_JSON" | jq -r '.score // 0')
    REVIEW_STATUS=$(echo "$RESULT_JSON" | jq -r '.status // "PASSED"')
    SUMMARY=$(echo "$RESULT_JSON" | jq -r '.summary // ""')
    BLOCKING=$(echo "$RESULT_JSON" | jq '[.issues[] | select(.severity=="blocking")] | length')
    WARNINGS=$(echo "$RESULT_JSON" | jq '[.issues[] | select(.severity=="warning")] | length')
    INFOS=$(echo "$RESULT_JSON" | jq '[.issues[] | select(.severity=="info")] | length')
  else
    echo "${YELLOW}⚠ Output Claude bukan JSON valid, menampilkan raw:${NC}"
    echo "$RESULT_RAW"
    SCORE=0
    REVIEW_STATUS="PASSED"
    SUMMARY="JSON parse error - review manual diperlukan"
    BLOCKING=0
    WARNINGS=0
    INFOS=0
  fi
else
  # Fallback tanpa jq
  SCORE="N/A"
  SUMMARY="(install jq untuk parsing detail)"
  if echo "$RESULT_RAW" | grep -q "BLOCKED"; then
    REVIEW_STATUS="BLOCKED"
    BLOCKING=1
  else
    REVIEW_STATUS="PASSED"
    BLOCKING=0
  fi
  WARNINGS=0
  INFOS=0
fi

# ── Tampilkan hasil ───────────────────────────────────────────
echo ""
echo "  📊 Hasil Review:"
echo "  ─────────────────────────────────────"
echo "  🔴 Blocking : $BLOCKING"
echo "  🟡 Warning  : $WARNINGS"
echo "  🔵 Info     : $INFOS"
echo "  ⭐ Score    : $SCORE / 100"
echo "  ⏱ Durasi   : ${REVIEW_DURATION}s"
if [ -n "$SUMMARY" ]; then
  echo "  📝 Summary  : $SUMMARY"
fi
echo "  ─────────────────────────────────────"

# ── Tampilkan detail issues ───────────────────────────────────
if [ "$BLOCKING" -gt 0 ] 2>/dev/null; then
  echo ""
  echo "${RED}  ❌ BLOCKING ISSUES:${NC}"
  if command -v jq > /dev/null 2>&1; then
    echo "$RESULT_JSON" | jq -r '.issues[] | select(.severity=="blocking") | "  → [\(.file):\(.line // "?")] \(.message)"' 2>/dev/null
  fi
fi

if [ "$WARNINGS" -gt 0 ] 2>/dev/null && [ "$WARNINGS" != "0" ]; then
  echo ""
  echo "${YELLOW}  ⚠ WARNINGS:${NC}"
  if command -v jq > /dev/null 2>&1; then
    echo "$RESULT_JSON" | jq -r '.issues[] | select(.severity=="warning") | "  → [\(.file):\(.line // "?")] \(.message)"' 2>/dev/null
  fi
fi

# ── Simpan log evidence KPI ───────────────────────────────────
mkdir -p "$LOG_DIR"
COMMIT_HASH=$(git rev-parse --short HEAD 2>/dev/null || echo "pending")

cat > "$LOG_FILE" << LOGEOF
{
  "timestamp": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "commit_hash": "$COMMIT_HASH",
  "branch": "$BRANCH",
  "status": "$REVIEW_STATUS",
  "files_reviewed": $FILE_COUNT,
  "duration_seconds": $REVIEW_DURATION,
  "score": $SCORE,
  "summary": "$SUMMARY",
  "issues": {
    "blocking": $BLOCKING,
    "warning": $WARNINGS,
    "info": $INFOS
  },
  "staged_files": [$(echo "$STAGED_FILES" | awk '{printf "%s\"%s\"", (NR>1?",":""), $0}')]
}
LOGEOF

echo ""
echo "  📁 Log: $LOG_FILE"

# ── Bersihkan file temp ───────────────────────────────────────
rm -f "$TEMP_DIFF" "$TEMP_RESULT"

# ── Keputusan final ───────────────────────────────────────────
echo ""
if [ "$REVIEW_STATUS" = "BLOCKED" ]; then
  echo "${RED}  ❌ COMMIT DITOLAK — Perbaiki blocking issues dulu${NC}"
  echo ""
  echo "  Setelah fix: git add <file> && git commit"
  echo "  Skip review (darurat): git commit --no-verify"
  echo ""
  exit 1
else
  echo "${GREEN}  ✅ REVIEW PASSED — Commit diizinkan${NC}"
  echo ""
  exit 0
fi