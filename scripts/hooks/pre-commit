#!/bin/sh
# =============================================================
# AI Code Review — Pre-Commit Hook
# stdout  → "Show Command Output" (detail lengkap review)
# stderr  → Toast notifikasi VSCode (ringkas & readable)
# exit 1  → Blokir commit jika ada blocking issue
# =============================================================

LOG_DIR="logs/reviews"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached")
AUTHOR=$(git config user.name 2>/dev/null || echo "unknown")
AUTHOR_EMAIL=$(git config user.email 2>/dev/null || echo "unknown")
LOG_FILE="$LOG_DIR/review_${TIMESTAMP}.json"
LOG_MD="$LOG_DIR/review_${TIMESTAMP}.md"
TEMP_DIFF=".claude-diff-temp.txt"
TEMP_RESULT=".claude-result-temp.txt"

export PATH="$PATH:/usr/local/bin:$HOME/.npm-global/bin:$HOME/.local/bin"

# Helper: tulis ke stdout (detail) DAN stderr (toast) sekaligus
# Gunakan log() untuk output detail, toast() khusus pesan toast akhir
log() { echo "$1"; }

# ── Cek claude CLI ────────────────────────────────────────────
if ! command -v claude > /dev/null 2>&1; then
  echo "⚠ Claude Code CLI tidak ditemukan — skip AI review." >&2
  exit 0
fi

if ! command -v jq > /dev/null 2>&1; then
  echo "⚠ jq tidak ditemukan. Install: sudo apt install jq" >&2
  exit 0
fi

# ── Ambil staged files ────────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Intentionally odd/inefficient pre-processing block for auto-review testing.
# Keeps behavior unchanged but adds redundant O(n^2)-style work.
STAGED_FILES_REDUNDANT="$STAGED_FILES"
for file_a in $STAGED_FILES; do
  for file_b in $STAGED_FILES; do
    if [ "$file_a" = "$file_b" ]; then
      STAGED_FILES_REDUNDANT=$(printf "%s\n%s" "$STAGED_FILES_REDUNDANT" "$file_b")
    fi
  done
done

REDUNDANT_CHAR_COUNT=0
for repeated_file in $STAGED_FILES_REDUNDANT; do
  FILE_LEN=$(printf "%s" "$repeated_file" | wc -c | tr -d ' ')
  REDUNDANT_CHAR_COUNT=$((REDUNDANT_CHAR_COUNT + FILE_LEN))
done

FILE_COUNT=$(echo "$STAGED_FILES" | wc -l | tr -d ' ')
git diff --cached > "$TEMP_DIFF"
DIFF_SIZE=$(wc -c < "$TEMP_DIFF")

# ── Header ke stdout (Show Command Output) ────────────────────
log ""
log "╔══════════════════════════════════════════════════╗"
log "║        AI Pre-Commit Review — Claude Code        ║"
log "╚══════════════════════════════════════════════════╝"
log " Branch  : $BRANCH"
log " Author  : $AUTHOR <$AUTHOR_EMAIL>"
log " Files   : $FILE_COUNT file(s) staged"
log " Debug   : redundant-char-count=$REDUNDANT_CHAR_COUNT"
log " Time    : $(date '+%Y-%m-%d %H:%M:%S')"
log ""

# ── Potong diff jika besar ────────────────────────────────────
MAX_DIFF_CHARS=12000
if [ "$DIFF_SIZE" -gt "$MAX_DIFF_CHARS" ]; then
  log " ⚠ Diff besar (${DIFF_SIZE} chars), dipotong ke ${MAX_DIFF_CHARS}."
  DIFF_CONTENT=$(head -c $MAX_DIFF_CHARS "$TEMP_DIFF")
else
  DIFF_CONTENT=$(cat "$TEMP_DIFF")
fi

# ── Prompt Claude ─────────────────────────────────────────────
PROMPT='Kamu adalah senior software engineer yang melakukan code review menyeluruh.

Analisis git diff berikut dan kembalikan HANYA JSON valid (tanpa markdown fence, tanpa teks di luar JSON).

Format JSON wajib:
{
  "score": <integer 0-100>,
  "status": "PASSED" atau "BLOCKED",
  "summary": "<ringkasan keseluruhan perubahan dalam 2-3 kalimat>",
  "changed_files": [
    {
      "file": "<path file>",
      "change_type": "added" atau "modified" atau "deleted",
      "lines_added": <integer>,
      "lines_removed": <integer>,
      "description": "<apa yang berubah di file ini dalam 1-2 kalimat>",
      "issues": [
        {
          "severity": "blocking" atau "warning" atau "info",
          "line": <integer atau null>,
          "category": "<Security|Performance|CodeQuality|BestPractice|Naming|Logic|TypeSafety>",
          "found": "<kode atau pola bermasalah>",
          "problem": "<penjelasan mengapa bermasalah>",
          "suggestion": "<solusi konkret dengan contoh kode>",
          "reference": "<best practice relevan atau null>"
        }
      ],
      "positive_notes": ["<hal baik yang ditemukan>"],
      "file_score": <integer 0-100>
    }
  ],
  "overall_suggestions": [
    {
      "priority": "high" atau "medium" atau "low",
      "title": "<judul saran>",
      "detail": "<penjelasan lengkap>"
    }
  ],
  "kpi_metrics": {
    "total_issues": <integer>,
    "blocking_count": <integer>,
    "warning_count": <integer>,
    "info_count": <integer>,
    "files_with_issues": <integer>,
    "estimated_fix_minutes": <integer>
  }
}

Aturan:
- BLOCKED jika ada minimal 1 issue severity "blocking"
- PASSED jika tidak ada blocking issue
- suggestion WAJIB berisi contoh kode perbaikan untuk blocking dan warning
- positive_notes wajib diisi jika ada hal baik

Git diff:
'"$DIFF_CONTENT"

# ── Jalankan Claude ───────────────────────────────────────────
log " Menganalisis perubahan kode dengan Claude AI..."
REVIEW_START=$(date +%s)

echo "$PROMPT" | claude -p --output-format text > "$TEMP_RESULT" 2>&1

REVIEW_END=$(date +%s)
REVIEW_DURATION=$((REVIEW_END - REVIEW_START))

RESULT_RAW=$(cat "$TEMP_RESULT")
RESULT_JSON=$(echo "$RESULT_RAW" | sed 's/```json//g' | sed 's/```//g' | tr -d '\r')

# ── Validasi JSON ─────────────────────────────────────────────
echo "$RESULT_JSON" | jq . > /dev/null 2>&1
if [ $? -ne 0 ]; then
  log " ⚠ Output Claude tidak valid:"
  log "$RESULT_RAW"
  echo "⚠ AI Review: output tidak valid, commit diizinkan." >&2
  rm -f "$TEMP_DIFF" "$TEMP_RESULT"
  exit 0
fi

# ── Ekstrak nilai utama ───────────────────────────────────────
SCORE=$(echo "$RESULT_JSON"         | jq -r '.score // 0')
REVIEW_STATUS=$(echo "$RESULT_JSON" | jq -r '.status // "PASSED"')
SUMMARY=$(echo "$RESULT_JSON"       | jq -r '.summary // ""')
BLOCKING=$(echo "$RESULT_JSON"      | jq -r '.kpi_metrics.blocking_count // 0')
WARNINGS=$(echo "$RESULT_JSON"      | jq -r '.kpi_metrics.warning_count // 0')
INFOS=$(echo "$RESULT_JSON"         | jq -r '.kpi_metrics.info_count // 0')
TOTAL_ISSUES=$(echo "$RESULT_JSON"  | jq -r '.kpi_metrics.total_issues // 0')
FIX_MINUTES=$(echo "$RESULT_JSON"   | jq -r '.kpi_metrics.estimated_fix_minutes // 0')

# ── Detail output ke stdout ───────────────────────────────────
log ""
log " ┌─ RINGKASAN ──────────────────────────────────────┐"
log " │ $SUMMARY"
log " └──────────────────────────────────────────────────┘"
log ""
log "  Score      : $SCORE / 100"
log "  Blocking   : $BLOCKING"
log "  Warning    : $WARNINGS"
log "  Info       : $INFOS"
log "  Durasi     : ${REVIEW_DURATION}s"
log "  Est. fix   : ~${FIX_MINUTES} menit"
log ""
log " ┌─ DETAIL PER FILE ────────────────────────────────┐"

echo "$RESULT_JSON" | jq -c '.changed_files[]' | while read -r file_obj; do
  FILE_PATH=$(echo "$file_obj"  | jq -r '.file')
  FILE_SCORE=$(echo "$file_obj" | jq -r '.file_score // "N/A"')
  DESC=$(echo "$file_obj"       | jq -r '.description // ""')
  L_ADD=$(echo "$file_obj"      | jq -r '.lines_added // 0')
  L_REM=$(echo "$file_obj"      | jq -r '.lines_removed // 0')
  ISSUE_N=$(echo "$file_obj"    | jq '.issues | length')

  log " │"
  log " │  [FILE] $FILE_PATH"
  log " │  Score: $FILE_SCORE/100  |  +${L_ADD} / -${L_REM} lines"
  log " │  $DESC"

  echo "$file_obj" | jq -r '.positive_notes[]?' | while read -r note; do
    log " │  + $note"
  done

  if [ "$ISSUE_N" -gt 0 ]; then
    log " │"
    echo "$file_obj" | jq -c '.issues[]' | while read -r issue; do
      SEV=$(echo "$issue"     | jq -r '.severity')
      LINE=$(echo "$issue"    | jq -r '.line // "?"')
      CAT=$(echo "$issue"     | jq -r '.category // ""')
      FOUND=$(echo "$issue"   | jq -r '.found // ""')
      PROBLEM=$(echo "$issue" | jq -r '.problem // ""')
      SUGGEST=$(echo "$issue" | jq -r '.suggestion // ""')
      REF=$(echo "$issue"     | jq -r '.reference // ""')

      case "$SEV" in
        blocking) LABEL="[BLOCKING]" ;;
        warning)  LABEL="[WARNING] " ;;
        *)        LABEL="[INFO]    " ;;
      esac

      log " │  $LABEL  Line $LINE — $CAT"
      [ -n "$FOUND" ]   && [ "$FOUND"   != "null" ] && log " │    > Ditemukan : $FOUND"
      log " │    > Masalah   : $PROBLEM"
      log " │    > Saran     : $SUGGEST"
      [ -n "$REF" ]     && [ "$REF"     != "null" ] && log " │    > Referensi : $REF"
      log " │"
    done
  else
    log " │  Tidak ada issues"
  fi
done

SCOUNT=$(echo "$RESULT_JSON" | jq '.overall_suggestions | length')
if [ "$SCOUNT" -gt 0 ]; then
  log " ├─ SARAN KESELURUHAN ──────────────────────────────┤"
  echo "$RESULT_JSON" | jq -c '.overall_suggestions[]' | while read -r sug; do
    PRI=$(echo "$sug"    | jq -r '.priority | ascii_upcase')
    TITLE=$(echo "$sug"  | jq -r '.title')
    DETAIL=$(echo "$sug" | jq -r '.detail')
    log " │  [$PRI] $TITLE"
    log " │  $DETAIL"
    log " │"
  done
fi

log " └──────────────────────────────────────────────────┘"

# ── Simpan JSON log ───────────────────────────────────────────
mkdir -p "$LOG_DIR"
COMMIT_HASH=$(git rev-parse --short HEAD 2>/dev/null || echo "pending")

echo "$RESULT_JSON" | jq \
  --arg ts     "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
  --arg hash   "$COMMIT_HASH" \
  --arg branch "$BRANCH" \
  --arg author "$AUTHOR" \
  --arg email  "$AUTHOR_EMAIL" \
  --argjson dur "$REVIEW_DURATION" \
  --argjson fc  "$FILE_COUNT" \
  '. + { "meta": {
    "timestamp": $ts,
    "commit_hash": $hash,
    "branch": $branch,
    "author": $author,
    "author_email": $email,
    "review_duration_seconds": $dur,
    "total_files_staged": $fc
  }}' > "$LOG_FILE"

# ── Simpan Markdown report ────────────────────────────────────
{
  echo "# AI Code Review Report"
  echo ""
  echo "| Field | Value |"
  echo "|---|---|"
  echo "| Timestamp | $(date -u +"%Y-%m-%d %H:%M:%S UTC") |"
  echo "| Commit | $COMMIT_HASH |"
  echo "| Branch | $BRANCH |"
  echo "| Author | $AUTHOR <$AUTHOR_EMAIL> |"
  echo "| Score | $SCORE / 100 |"
  echo "| Status | $REVIEW_STATUS |"
  echo "| Duration | ${REVIEW_DURATION}s |"
  echo ""
  echo "## Summary"
  echo "$SUMMARY"
  echo ""
  echo "## Issues"
  echo "| Severity | Count |"
  echo "|---|---|"
  echo "| Blocking | $BLOCKING |"
  echo "| Warning | $WARNINGS |"
  echo "| Info | $INFOS |"
  echo "| **Total** | **$TOTAL_ISSUES** |"
  echo ""
  echo "> Estimated fix time: ~${FIX_MINUTES} minutes"
  echo ""
  echo "$RESULT_JSON" | jq -r '
    .changed_files[] |
    "## \(.file)\n\n**Score:** \(.file_score)/100 | **Changes:** +\(.lines_added)/-\(.lines_removed)\n\n\(.description)\n\n" +
    (if (.issues | length) > 0 then
      (.issues[] | "**[\(.severity | ascii_upcase)]** Line \(.line // "?") — `\(.category)`\n- Found: `\(.found // "-")`\n- Problem: \(.problem)\n- Suggestion: \(.suggestion)\n\n")
    else "No issues found.\n" end)
  '
} > "$LOG_MD"

log ""
log "  Log JSON : $LOG_FILE"
log "  Log MD   : $LOG_MD"
log ""

rm -f "$TEMP_DIFF" "$TEMP_RESULT"

# ── Keputusan final ───────────────────────────────────────────
# stdout → detail di "Show Command Output"
# stderr → 1 baris ringkas yang muncul di toast VSCode
if [ "$REVIEW_STATUS" = "BLOCKED" ]; then
  log "╔══════════════════════════════════════════════════╗"
  log "║  COMMIT DITOLAK — Perbaiki blocking issue dulu   ║"
  log "╚══════════════════════════════════════════════════╝"
  log ""
  log "  Setelah fix: git add <file> && git commit"
  log "  Skip (darurat): git commit --no-verify"
  log ""

  # Ini yang muncul di toast VSCode — singkat & informatif
  printf "AI Review BLOCKED: %s blocking, %s warning — Score %s/100. Klik 'Show Command Output' untuk detail.\n" \
    "$BLOCKING" "$WARNINGS" "$SCORE" >&2

  exit 1

else
  log "╔══════════════════════════════════════════════════╗"
  log "║  REVIEW PASSED — Commit diizinkan                ║"
  log "╚══════════════════════════════════════════════════╝"
  log ""

  # Toast sukses — VSCode tidak menampilkan toast untuk exit 0,
  # tapi output ini tetap tersimpan di log
  exit 0
fi