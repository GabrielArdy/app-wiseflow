#!/bin/sh
# =============================================================
# AI Code Review - Pre-Commit Hook
# Tools: Claude Code + VSCode + Bitbucket
# Tujuan: Review otomatis sebelum commit, log sebagai evidence KPI
# =============================================================

# ── Konfigurasi ──────────────────────────────────────────────
REVIEW_CONFIG=".claude-review-config.json"
LOG_DIR="logs/reviews"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached")
COMMIT_MSG_FILE=".git/COMMIT_EDITMSG"
LOG_FILE="$LOG_DIR/review_${TIMESTAMP}.json"
TEMP_REVIEW=".claude-review-temp.json"

# Warna output terminal
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ── Cek apakah Claude Code tersedia ─────────────────────────
if ! command -v claude > /dev/null 2>&1; then
  echo "${YELLOW}⚠ Claude Code CLI tidak ditemukan. Skip AI review.${NC}"
  echo "  Install dengan: npm install -g @anthropic-ai/claude-code"
  exit 0
fi

# ── Ambil list file yang di-stage ────────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "${BLUE}ℹ Tidak ada file yang di-stage. Skip review.${NC}"
  exit 0
fi

FILE_COUNT=$(echo "$STAGED_FILES" | wc -l | tr -d ' ')

echo ""
echo "${BLUE}┌─────────────────────────────────────────┐${NC}"
echo "${BLUE}│   🤖 Claude Code - AI Pre-Commit Review  │${NC}"
echo "${BLUE}└─────────────────────────────────────────┘${NC}"
echo "  Branch  : $BRANCH"
echo "  Files   : $FILE_COUNT file(s) akan direview"
echo "  Time    : $(date '+%Y-%m-%d %H:%M:%S')"
echo ""

# ── Buat folder log jika belum ada ───────────────────────────
mkdir -p "$LOG_DIR"

# ── Jalankan Claude Code Review ──────────────────────────────
echo "${BLUE}⏳ Menjalankan AI review...${NC}"
REVIEW_START=$(date +%s)

# Jalankan review dengan output JSON
if [ -f "$REVIEW_CONFIG" ]; then
  claude review --staged --config "$REVIEW_CONFIG" --output json > "$TEMP_REVIEW" 2>&1
else
  claude review --staged --output json > "$TEMP_REVIEW" 2>&1
fi

REVIEW_EXIT=$?
REVIEW_END=$(date +%s)
REVIEW_DURATION=$((REVIEW_END - REVIEW_START))

# ── Parse hasil review ───────────────────────────────────────
if [ -f "$TEMP_REVIEW" ] && command -v jq > /dev/null 2>&1; then
  BLOCKING=$(jq '.issues // [] | map(select(.severity == "blocking")) | length' "$TEMP_REVIEW" 2>/dev/null || echo "0")
  WARNINGS=$(jq '.issues // [] | map(select(.severity == "warning")) | length' "$TEMP_REVIEW" 2>/dev/null || echo "0")
  INFOS=$(jq '.issues // [] | map(select(.severity == "info")) | length' "$TEMP_REVIEW" 2>/dev/null || echo "0")
  SCORE=$(jq '.score // "N/A"' "$TEMP_REVIEW" 2>/dev/null || echo "N/A")
else
  # Fallback jika jq tidak tersedia
  BLOCKING=0
  WARNINGS=0
  INFOS=0
  SCORE="N/A"
fi

# ── Tampilkan ringkasan hasil ─────────────────────────────────
echo ""
echo "  📊 Hasil Review:"
echo "  ─────────────────────────────────────"
echo "  🔴 Blocking issues : $BLOCKING"
echo "  🟡 Warnings        : $WARNINGS"
echo "  🔵 Info            : $INFOS"
echo "  ⭐ Score           : $SCORE / 100"
echo "  ⏱ Durasi review   : ${REVIEW_DURATION}s"
echo "  ─────────────────────────────────────"

# ── Tampilkan detail issues jika ada ─────────────────────────
if [ "$BLOCKING" -gt 0 ] 2>/dev/null; then
  echo ""
  echo "${RED}  ❌ BLOCKING ISSUES yang harus diperbaiki:${NC}"
  if command -v jq > /dev/null 2>&1 && [ -f "$TEMP_REVIEW" ]; then
    jq -r '.issues // [] | map(select(.severity == "blocking")) | .[] | "  → [\(.file):\(.line // "?")] \(.message)"' "$TEMP_REVIEW" 2>/dev/null
  fi
fi

if [ "$WARNINGS" -gt 0 ] 2>/dev/null && [ "$WARNINGS" != "0" ]; then
  echo ""
  echo "${YELLOW}  ⚠ WARNINGS (tidak memblokir commit):${NC}"
  if command -v jq > /dev/null 2>&1 && [ -f "$TEMP_REVIEW" ]; then
    jq -r '.issues // [] | map(select(.severity == "warning")) | .[] | "  → [\(.file):\(.line // "?")] \(.message)"' "$TEMP_REVIEW" 2>/dev/null
  fi
fi

# ── Tentukan status commit ────────────────────────────────────
if [ "$BLOCKING" -gt 0 ] 2>/dev/null; then
  REVIEW_STATUS="BLOCKED"
else
  REVIEW_STATUS="PASSED"
fi

# ── Simpan evidence log (untuk KPI) ──────────────────────────
COMMIT_HASH=$(git rev-parse --short HEAD 2>/dev/null || echo "pending")

cat > "$LOG_FILE" << EOF
{
  "timestamp": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "commit_hash": "$COMMIT_HASH",
  "branch": "$BRANCH",
  "status": "$REVIEW_STATUS",
  "files_reviewed": $FILE_COUNT,
  "duration_seconds": $REVIEW_DURATION,
  "score": $SCORE,
  "issues": {
    "blocking": $BLOCKING,
    "warning": $WARNINGS,
    "info": $INFOS
  },
  "staged_files": [
$(echo "$STAGED_FILES" | awk '{printf "    \"%s\"", $0; if (NR>1) printf ",\n"; else printf "\n"}' | sort)
  ]
}
EOF

echo ""
echo "  📁 Log disimpan: $LOG_FILE"

# ── Hapus file temp ───────────────────────────────────────────
rm -f "$TEMP_REVIEW"

# ── Keputusan final ───────────────────────────────────────────
echo ""
if [ "$REVIEW_STATUS" = "PASSED" ]; then
  echo "${GREEN}  ✅ REVIEW PASSED — Commit diizinkan${NC}"
  echo ""
  exit 0
else
  echo "${RED}  ❌ REVIEW BLOCKED — Perbaiki blocking issues dulu${NC}"
  echo ""
  echo "  Cara fix:"
  echo "  1. Perbaiki issues di atas"
  echo "  2. git add <files>"
  echo "  3. git commit (review akan dijalankan ulang)"
  echo ""
  echo "  Untuk skip review (darurat): git commit --no-verify"
  echo ""
  exit 1
fi
